---
import "../styles/global.css";
---

<div class="min-h-screen flex flex-col justify-center items-center text-white">
  <h1 class="text-5xl font-bold text-center">
    Welcome <span class="wave">👋</span>, I'm <br /> Syawalan finanda
  </h1>

  <p class="mt-4 text-lg font-semibold text-gray-300">
    Available to help you with:
  </p>
  <!-- card section -->
  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6 max-w-4xl">
    <!-- frontend development card -->
    <div
      class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20"
    >
      <div class="flex items-center space-x-4">
        <svg
          class="w-10 h-10 text-blue-500"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path d="M3 4v16h18V4H3zm16 14H5V6h14v12z"></path>
        </svg>
      </div>
      <h2 class="text-xl font-semibold">Frontend Development</h2>
      <p class="mt-2 text-gray-300">
        Expert in creating dynamic and responsive user interfaces using <span
          class="text-blue-400">React</span
        > and <span class="text-blue-400">Astro</span>. I bring your designs to
        life with clean, efficient, and maintainable code.
      </p>
    </div>

    <!-- backend Developemtn card -->
    <div
      class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 shadow-lg"
    >
      <div class="flex items-center space-x-4">
        <div class="bg-yellow-500/20 p-3 rounded-full">
          <svg
            class="w-10 h-10 text-yellow-500"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M3 4v16h18V4H3zm16 14H5V6h14v12z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-semibold">Backend Development</h2>
      </div>
      <p class="mt-2 text-gray-300">
        Skilled in building scalable server-side applications with <span
          class="text-yellow-400">Laravel</span
        > and <span class="text-yellow-400">Express</span>. I ensure your
        backend is secure, efficient, and seamlessly integrated with your
        frontend.
      </p>
    </div>
  </div>
</div>
